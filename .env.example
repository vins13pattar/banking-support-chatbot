# =============================================================================
# Banking Support Chatbot - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Configuration ---
OPENAI_API_KEY=your-openai-api-key-here

# --- LangSmith Configuration ---
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=banking-support-chatbot
LANGSMITH_TRACING=true

# --- Database Configuration ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/banking_chatbot

# --- LangGraph Agent Server ---
# Used by langgraph.json and the Agent Server
LANGGRAPH_API_URL=http://localhost:2024

# --- Admin Dashboard (Vite) ---
VITE_LANGGRAPH_API_URL=http://localhost:2024
VITE_SUPPORT_API_URL=http://localhost:8000
VITE_APP_ENV=development
